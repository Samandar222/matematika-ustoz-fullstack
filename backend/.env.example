# Portni o'zgartirishingiz mumkin
PORT=4000

# Frontend manzili (CORS uchun)
CLIENT_ORIGIN=http://localhost:5173

# JWT token uchun maxfiy kalit - buni albatta uzun, tasodifiy qatorga almashtiring
JWT_SECRET=juda-maxfiy-va-uzun-random-key-buni-almashtiring

# Admin login ma'lumotlari
# ADMIN_PASSWORD_HASH ni yaratish uchun: npm run create-admin
# (skript sizdan login va parol so'raydi, keyin hash qilingan qiymatni shu yerga yozadi)
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=

# Telegramga darhol xabar yuborish (ixtiyoriy, lekin tavsiya etiladi)
# 1) Telegramda @BotFather ga yozing -> /newbot -> nom bering -> u sizga TOKEN beradi
# 2) O'zingizning botingizga (yoki guruhga) bitta xabar yozing
# 3) Brauzerda oching: https://api.telegram.org/bot<TOKEN>/getUpdates
#    Javobdagi "chat":{"id": ...} qiymati - shu sizning CHAT ID
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
